    name = "Nelson Stoik"

[init]
    defaultBranch = main

[push]
    # auto-setup tracking branch on first push (no need for --set-upstream)
    autoSetupRemote = true

[pull]
    # rebase instead of merge on git pull for cleaner history
    rebase = true

[fetch]
    # remove stale remote-tracking refs (e.g. origin/old-branch) after fetch
    prune = true

[rerere]
    # remember and reuse conflict resolutions automatically
    enabled = true

[diff]
    # highlight moved code blocks differently from added/removed lines
    colorMoved = zebra

[merge]
    # show common ancestor in conflict markers for easier resolution
    conflictstyle = zdiff3

[core]
    # override the default pager. 
    #  https://stackoverflow.com/questions/2183900/how-do-i-prevent-git-diff-from-using-a-pager/14118014#14118014
    pager = "less -F -X"

    # set the autocrlf setting to input
    autocrlf = input

    # set the filemode to false
    # https://stackoverflow.com/questions/1257592/how-do-i-remove-files-saying-old-mode-100755-new-mode-100644-from-unstaged-cha
    filemode = false
